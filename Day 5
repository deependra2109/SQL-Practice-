1.Find users whose transaction amount is greater than average

SELECT user_id, amount FROM transactions
WHERE amount > 
( SELECT AVG(amount) FROM transactions);

2.Find users who have made at least 1 transaction

SELECT * FROM users
WHERE user_id IN 
(SELECT user_id FROM transactions);

OR Another way

SELECT * FROM users u
WHERE EXISTS 
( SELECT 1 FROM transactions t
    WHERE t.user_id = u.user_id
);

3.Find users who never made any transaction

SELECT *
FROM users u
WHERE NOT EXISTS 
( SELECT 1 FROM transactions t
    WHERE t.user_id = u.user_id
);

4.Find users whose total transaction amount > average total amount

SELECT user_id, SUM(amount) AS total FROM transactions
GROUP BY user_id HAVING total > (
    SELECT AVG(total_amount)
    FROM ( SELECT SUM(amount) AS total_amount
        FROM transactions
        GROUP BY user_id
    ) temp );

5.Find users who made a transaction greater than their own average

SELECT DISTINCT user_id
FROM transactions t1
WHERE amount > (
    SELECT AVG(amount)
    FROM transactions t2
    WHERE t2.user_id = t1.user_id
);

6.Find users who made the maximum transaction

SELECT * FROM transactions
WHERE amount = ( SELECT MAX(amount)
FROM transactions
);

7.Find users whose every transaction is SUCCESS

SELECT user_id
FROM transactions
GROUP BY user_id
HAVING SUM(CASE WHEN status != 'SUCCESS' THEN 1 ELSE 0 END) = 0;
