1.user name + transaction amount

SELECT u.name, t.amount
FROM users u
INNER JOIN transactions t
ON u.user_id = t.user_id;


2.users with no transactions

SELECT u.name
FROM users u
LEFT JOIN transactions t
ON u.user_id = t.user_id
WHERE t.user_id IS NULL;

3.users with total transaction amount > 1000

SELECT u.name, SUM(t.amount) AS total_amount
FROM users u
INNER JOIN transactions t
ON u.user_id = t.user_id
GROUP BY u.name
HAVING total_amount > 1000;
